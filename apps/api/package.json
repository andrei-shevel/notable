{
  "name": "@notable/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node build.js",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1058.0",
    "@aws-sdk/lib-storage": "^3.1058.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@notable/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-metrics": "^13.2.1",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^6.1.0",
    "nodemailer": "^8.0.10",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@notable/editor": "workspace:*",
    "@testcontainers/postgresql": "^12.0.3",
    "@types/node": "^24.12.4",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
