# Notable — copy this file to .env and fill in real values.
#
#   cp .env.example .env
#
# .env is gitignored (see .gitignore). The compose stack reads from it
# automatically when run from the repo root.

# Postgres superuser password. Use `openssl rand -hex 24` or similar.
POSTGRES_PASSWORD=replace-me

# HS256 signing secret for session JWTs. Must be at least 32 bytes of entropy.
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-me

# SMTP connection URL used to send magic-link emails.
#   dev   -> smtp://mailpit:1025          (set automatically by docker-compose.dev.yml)
#   prod  -> smtps://user:pass@host:587
SMTP_URL=smtp://mailpit:1025

# Public origin used to build magic-link URLs. No trailing slash.
#   dev   -> http://localhost:5173        (Vite dev server)
#   prod  -> https://notable.example.com  (matches PUBLIC_HOSTNAME below)
PUBLIC_URL=http://localhost:5173

# Hostname Caddy binds to. Use "localhost" for HTTP-only local dev; use a real
# DNS name in prod and Caddy will provision a Let's Encrypt cert automatically.
PUBLIC_HOSTNAME=localhost
