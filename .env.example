# Notable — copy this file to .env and fill in real values.
#
#   cp .env.example .env
#
# .env is gitignored (see .gitignore). The compose stack reads from it
# automatically when run from the repo root.

# Postgres superuser password. Use `openssl rand -hex 24` or similar.
POSTGRES_PASSWORD=replace-me

# HS256 signing secret for session JWTs. Must be at least 32 bytes of entropy.
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-me

# SMTP connection URL used to send magic-link emails.
#   dev   -> smtp://mailpit:1025          (set automatically by docker-compose.dev.yml)
#   prod  -> smtps://user:pass@host:587
SMTP_URL=smtp://mailpit:1025

# From address on outbound mail. Must be a domain the SMTP relay is willing
# to send for. Mailpit accepts anything in dev.
MAIL_FROM=Notable <noreply@notable.local>

# Public URL where the SPA is reachable (origin + base path, no trailing /).
# The api builds magic-link URLs as `${PUBLIC_URL}/auth/verify?token=...`.
#   dev   -> http://localhost:5173/app                  (Vite dev server, /app base)
#   prod  -> https://notable.example.com/app            (Caddy serves SPA there)
PUBLIC_URL=http://localhost:5173/app

# Hostname Caddy binds to. Use "localhost" for HTTP-only local dev; use a real
# DNS name in prod and Caddy will provision a Let's Encrypt cert automatically.
PUBLIC_HOSTNAME=localhost

# MinIO / S3-compatible object storage credentials. In dev these double as the
# MinIO root user/password (the dev console is at http://localhost:9001).
# MINIO_ROOT_USER must be 3+ chars; MINIO_ROOT_PASSWORD must be 8+ chars.
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Bucket the api reads/writes. Region is only meaningful for real S3; MinIO
# ignores it but the AWS SDK requires *some* value.
S3_BUCKET=notable
S3_REGION=us-east-1
